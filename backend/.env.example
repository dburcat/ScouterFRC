# ScouterFRC Database Configuration

# PostgreSQL Connection String
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://username:password@localhost:5432/scouterfrc

# Optional: Separate credentials (if not using DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=scouterfrc
DB_USER=postgres
DB_PASSWORD=your_password_here

# SQLAlchemy Settings
SQLALCHEMY_ECHO=True
SQLALCHEMY_POOL_SIZE=5
SQLALCHEMY_MAX_OVERFLOW=10

# Application Settings
APP_ENV=development
DEBUG=True

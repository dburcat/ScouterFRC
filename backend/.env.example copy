# ScouterFRC Database Configuration

# PostgreSQL Connection String
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:password@localhost:5432/scouterfrc

# Optional: Separate credentials (if not using DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=scouterfrc
DB_USER=postgres
DB_PASSWORD=password

# SQLAlchemy Settings
SQLALCHEMY_ECHO=True
SQLALCHEMY_POOL_SIZE=5
SQLALCHEMY_MAX_OVERFLOW=10

# Application Settings
APP_ENV=development
DEBUG=True

# ── Celery & Redis (Phase 2) ────────────────────────────────────────────────
# Redis broker URL (matches the 'redis' service in docker-compose.yml)
REDIS_URL=redis://redis:6379/0
# Separate DB for Celery result backend
REDIS_RESULT_URL=redis://redis:6379/1

# Flower basic-auth credentials (Celery monitoring UI at :5555)
FLOWER_USER=admin
FLOWER_PASSWORD=admin
